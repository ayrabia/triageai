# Anthropic / Claude (used for direct API fallback only — primary path is Bedrock)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (fallback classifier)
OPENAI_API_KEY=sk-...

# AWS credentials + config
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# S3 — raw fax archive (AES-256 SSE at bucket level)
S3_BUCKET=triageai-test-referrals

# SQS — referral processing queue
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/triageai-referral-jobs

# Bedrock model ID
CLAUDE_MODEL_ID=us.anthropic.claude-sonnet-4-6

# PostgreSQL (RDS db.t4g.micro ~$12/mo)
DATABASE_URL=postgresql://triageai:password@your-rds-host.rds.amazonaws.com:5432/triageai

# Fax ingestion — Phaxio
PHAXIO_API_KEY=...
PHAXIO_API_SECRET=...

# Multi-clinic: default clinic ID (maps fax number → clinic)
DEFAULT_CLINIC_ID=sacent

# AWS Cognito — JWT authentication
# Create a User Pool in AWS Console → Cognito → User Pools
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
